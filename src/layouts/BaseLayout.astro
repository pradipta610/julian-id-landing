---
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Loader from '../components/Loader.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
  showLoader?: boolean;
  showCursor?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  schema,
  noindex = false,
  showLoader = true,
  showCursor = true,
} = Astro.props;
---
<!doctype html>
<html lang="id">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      schema={schema}
      noindex={noindex}
    />
    <ClientRouter />
  </head>
  <body>
    <!-- Pre-paint: hide loader instantly on subsequent navigations to avoid flash -->
    <script is:inline>
      (function () {
        try {
          if (sessionStorage.getItem('julian_loaded_v1')) {
            document.documentElement.classList.add('skip-loader');
          }
        } catch (e) { /* sessionStorage unavailable — fall through */ }
      })();
    </script>

    {showLoader && <Loader />}
    {showCursor && <CustomCursor />}
    <Nav />

    <slot />

    <Footer />
    <FloatingActions />

    <script src="../scripts/animations.js"></script>
  </body>
</html>
