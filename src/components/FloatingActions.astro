---
// Floating Actions — bottom-right cluster
// - WhatsApp (primary, gold accent)
// - Instagram Outdoor + Studio
// - Facebook
// - Scroll-to-Top (appears after scroll, with circular progress ring)
//
// Responsive: 56px desktop / 48px mobile, repositions to avoid bottom safe-area on iOS.

interface Props {
  whatsappNumber?: string;
  whatsappMessage?: string;
  instagramOutdoor?: string;
  instagramStudio?: string;
  facebook?: string;
}

const {
  whatsappNumber = '6282145945051',
  whatsappMessage = 'Halo Julian Photography, saya tertarik dengan layanan foto kalian.',
  instagramOutdoor = 'https://www.instagram.com/julian_photography/',
  instagramStudio = 'https://www.instagram.com/julianphotostudio',
  facebook = 'https://www.facebook.com/juliankomang6',
} = Astro.props;

const waUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---
<aside class="fab" id="fab" aria-label="Aksi cepat">
  <!-- ===== Toggle (mobile/tablet only) — collapses the social cluster ===== -->
  <button
    type="button"
    class="fab-toggle"
    id="fabToggle"
    aria-label="Buka menu kontak cepat"
    aria-expanded="false"
    aria-controls="fabCluster"
    data-hover
  >
    <span class="fab-toggle-icon" aria-hidden="true">
      <span class="fab-toggle-dot"></span>
      <span class="fab-toggle-dot"></span>
      <span class="fab-toggle-dot"></span>
    </span>
    <span class="fab-toggle-label">Kontak</span>
  </button>

  <!-- ===== Action cluster ===== -->
  <div class="fab-cluster" id="fabCluster" role="group">
    <!-- WhatsApp — primary -->
    <a
      href={waUrl}
      target="_blank"
      rel="noopener"
      class="fab-btn fab-btn-wa"
      aria-label="Chat via WhatsApp"
      data-hover
      data-fab-tip="Chat WhatsApp"
    >
      <span class="fab-btn-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
        </svg>
      </span>
      <span class="fab-btn-pulse" aria-hidden="true"></span>
      <span class="fab-btn-tip">Chat WhatsApp</span>
    </a>

    <!-- Instagram Outdoor -->
    <a
      href={instagramOutdoor}
      target="_blank"
      rel="noopener"
      class="fab-btn fab-btn-ig"
      aria-label="Instagram Outdoor"
      data-hover
      data-fab-tip="Instagram Outdoor"
    >
      <span class="fab-btn-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
      </span>
      <span class="fab-btn-tip">@julian_photography</span>
    </a>

    <!-- Instagram Studio -->
    <a
      href={instagramStudio}
      target="_blank"
      rel="noopener"
      class="fab-btn fab-btn-ig-studio"
      aria-label="Instagram Studio"
      data-hover
      data-fab-tip="Instagram Studio"
    >
      <span class="fab-btn-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="3" width="18" height="18" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
      </span>
      <span class="fab-btn-tip">@julianphotostudio</span>
    </a>

    <!-- Facebook -->
    <a
      href={facebook}
      target="_blank"
      rel="noopener"
      class="fab-btn fab-btn-fb"
      aria-label="Facebook"
      data-hover
      data-fab-tip="Facebook"
    >
      <span class="fab-btn-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </span>
      <span class="fab-btn-tip">Facebook</span>
    </a>
  </div>

  <!-- ===== Scroll to Top (with circular progress ring) ===== -->
  <button
    type="button"
    class="fab-btn fab-btn-top"
    id="fabScrollTop"
    aria-label="Kembali ke atas"
    data-hover
    data-fab-tip="Ke atas"
  >
    <!-- Circular progress ring (SVG) -->
    <svg class="fab-progress" viewBox="0 0 56 56" aria-hidden="true">
      <circle class="fab-progress-track" cx="28" cy="28" r="25" fill="none" stroke-width="1.5"/>
      <circle class="fab-progress-bar" cx="28" cy="28" r="25" fill="none" stroke-width="1.5"
        pathLength="100" stroke-dasharray="100 100" stroke-dashoffset="100"
      />
    </svg>
    <span class="fab-btn-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <path d="M12 19V5M5 12l7-7 7 7"/>
      </svg>
    </span>
    <span class="fab-btn-tip">Ke atas</span>
  </button>
</aside>

<script is:inline data-astro-rerun>
  (function () {
    function initFAB() {
      var fab = document.getElementById('fab');
      var toggle = document.getElementById('fabToggle');
      var scrollBtn = document.getElementById('fabScrollTop');
      if (!fab) return;

      // ----- 1. Mobile collapse toggle -----
      if (toggle && !toggle.dataset.bound) {
        toggle.dataset.bound = '1';
        toggle.addEventListener('click', function () {
          var isOpen = fab.classList.toggle('is-open');
          toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          toggle.setAttribute('aria-label', isOpen ? 'Tutup menu kontak cepat' : 'Buka menu kontak cepat');
        });
      }

      // ----- 2. Scroll-to-top + progress ring + visibility -----
      var progressBar = fab.querySelector('.fab-progress-bar');

      function getScrollPercent() {
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        var max = (document.documentElement.scrollHeight - window.innerHeight) || 1;
        return Math.max(0, Math.min(100, (scrollTop / max) * 100));
      }

      function updateProgress() {
        var pct = getScrollPercent();
        if (progressBar) {
          // dasharray length is 100, so dashoffset goes from 100 (empty) to 0 (full)
          progressBar.style.strokeDashoffset = String(100 - pct);
        }
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        if (scrollTop > 400) fab.classList.add('is-scrolled');
        else fab.classList.remove('is-scrolled');
      }

      if (scrollBtn && !scrollBtn.dataset.bound) {
        scrollBtn.dataset.bound = '1';
        scrollBtn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      if (!window.__fabScrollBound) {
        window.__fabScrollBound = true;
        var rafPending = false;
        window.addEventListener('scroll', function () {
          if (rafPending) return;
          rafPending = true;
          window.requestAnimationFrame(function () {
            updateProgress();
            rafPending = false;
          });
        }, { passive: true });
      }

      // Initial state
      updateProgress();

      // ----- 3. Hide FAB when mobile menu is open (avoid visual conflict) -----
      // Watch for body.no-scroll class which is added when mobile menu opens
      if (!window.__fabMenuObserverBound) {
        window.__fabMenuObserverBound = true;
        var obs = new MutationObserver(function () {
          if (document.body.classList.contains('no-scroll')) {
            fab.classList.add('is-hidden');
          } else {
            fab.classList.remove('is-hidden');
          }
        });
        obs.observe(document.body, { attributes: true, attributeFilter: ['class'] });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFAB);
    } else {
      initFAB();
    }
    document.addEventListener('astro:page-load', initFAB);
  })();
</script>
