    <div class="footer-socials">
      <a href="https://www.instagram.com/julian_photography/" target="_blank" rel="noopener" data-hover>IG Outdoor</a>
      <a href="https://www.instagram.com/julianphotostudio" target="_blank" rel="noopener" data-hover>IG Studio</a>
      <a href="https://www.facebook.com/juliankomang6" target="_blank" rel="noopener" data-hover>Facebook</a>
      <a href="https://wa.me/6282145945051" target="_blank" rel="noopener" data-hover>WhatsApp</a>
    </div>
    <div>Made in Bali</div>
  </div>
</footer>
