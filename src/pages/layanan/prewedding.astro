---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import CTA from '../../components/home/CTA.astro';
import { url } from '../../utils/url';
import { relatedTo } from '../../data/services';

const title = 'Prewedding Photography Bali';
const description =
  'Sesi prewedding outdoor di Bali — Uluwatu, Ubud, Canggu, Nusa Penida, Tegallalang. Style natural, sinematik, lokasi-driven. Konsultasi via WhatsApp 0821-4594-5051.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Prewedding Photography',
  description,
  provider: { '@id': 'https://juliansphotography.com/#business' },
  areaServed: { '@type': 'AdministrativeArea', name: 'Bali, Indonesia' },
  serviceType: 'Prewedding Photography',
};

const includes = [
  { icon: 'I', name: 'Konsultasi Konsep', desc: 'Diskusi tema, mood board, dan referensi sebelum hari sesi agar arah visual jelas.' },
  { icon: 'II', name: 'Outdoor Session', desc: 'Sesi 4–6 jam di 1–2 lokasi, dengan timing menyesuaikan golden hour terbaik.' },
  { icon: 'III', name: '2–3 Outfit Changes', desc: 'Perpindahan outfit untuk variasi look — dari casual hingga formal.' },
  { icon: 'IV', name: 'Edited Hi-Res Photos', desc: '60–120+ foto edited dengan tone konsisten, siap cetak hingga A2.' },
  { icon: 'V', name: 'Online Gallery', desc: 'Akses gallery online untuk download high-res, sharing ke vendor & undangan.' },
  { icon: 'VI', name: 'Pre-Visit Lokasi (Opsional)', desc: 'Untuk konsep spesifik, kami bisa pre-visit lokasi untuk plotting komposisi & timing.' },
];

const popularLocations = [
  { name: 'Uluwatu', desc: 'Tebing dramatis dengan ombak besar di bawah. Best timing 30 menit sebelum sunset. Cocok untuk look romantis dengan dress flowy.', tag: 'Sunset Cliff' },
  { name: 'Ubud — Sawah & Hutan', desc: 'Sawah hijau Tegallalang & hutan Campuhan. Best timing pagi (sebelum 9 AM) untuk soft mist. Tema natural, earthy, intimate.', tag: 'Sawah Hijau' },
  { name: 'Canggu & Seminyak', desc: 'Beach club, pantai vulkanik hitam, atau jalanan vintage Canggu. Best timing afternoon menjelang sunset. Vibe casual & modern.', tag: 'Beach Vibe' },
  { name: 'Nusa Penida', desc: 'Kelingking Beach, Diamond Beach, atau Broken Beach. Trip 1–2 hari. Cocok untuk konsep epic landscape + adventure.', tag: 'Pulau Tropis' },
  { name: 'Tegallalang Rice Terrace', desc: 'Sawah berundak ikonik. Best timing pagi 6.30–8.30 WITA. Tema traditional Bali atau boho-natural.', tag: 'Rice Terrace' },
  { name: 'Nusa Dua & Sanur', desc: 'Pantai pasir putih tenang dengan pohon palem. Cocok untuk look classic, soft, family-friendly.', tag: 'Pantai Tenang' },
];

const wardrobeTips = [
  { name: 'Koordinasi Warna', desc: 'Pilih palette 2–3 warna komplementer. Hindari pure white di outdoor karena bisa over-expose. Earth tone (cream, sage, terracotta) sangat fotogenik di Bali.', meta: 'Palette' },
  { name: 'Hindari Logo & Pattern Besar', desc: 'Polos atau pattern halus akan timeless. Logo brand besar bisa mengalihkan fokus dari ekspresi & momen.', meta: 'Print' },
  { name: 'Outfit Mengalir untuk Outdoor', desc: 'Kain flowy (chiffon, silk, linen) lebih fotogenik di pantai/sawah karena bergerak natural dengan angin. Cocok untuk shot sinematik.', meta: 'Fabric' },
  { name: 'Sepatu yang Nyaman', desc: 'Untuk lokasi seperti Uluwatu (banyak tangga) atau sawah (becek), siapkan sneakers atau flat sandals untuk pindah-pindah.', meta: 'Footwear' },
  { name: 'Aksesori Minimalis', desc: 'Anting kecil, kalung simple. Aksesori berlebih bisa ribet untuk outdoor windy. Less is more di Bali.', meta: 'Accessories' },
];

const gallery = [
  { src: 'https://images.unsplash.com/photo-1523438097201-512ae7d7c424?w=1200&q=85&auto=format&fit=crop', loc: 'Uluwatu', cls: 'gi-wide' },
  { src: 'https://images.unsplash.com/photo-1465495976277-4387d4b0e4a6?w=900&q=85&auto=format&fit=crop', loc: 'Ubud', cls: 'gi-tall' },
  { src: 'https://images.unsplash.com/photo-1469371670807-013ccf25f16a?w=1200&q=85&auto=format&fit=crop', loc: 'Seminyak', cls: '' },
  { src: 'https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=1000&q=85&auto=format&fit=crop', loc: 'Tegallalang', cls: '' },
  { src: 'https://images.unsplash.com/photo-1520854221256-17451cc331bf?w=1200&q=85&auto=format&fit=crop', loc: 'Sanur', cls: '' },
  { src: 'https://images.unsplash.com/photo-1537907510278-10acdb198d0f?w=1200&q=85&auto=format&fit=crop', loc: 'Nusa Penida', cls: 'gi-wide' },
  { src: 'https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=900&q=85&auto=format&fit=crop', loc: 'Nusa Dua', cls: 'gi-tall' },
  { src: 'https://images.unsplash.com/photo-1519741497674-611481863552?w=1200&q=85&auto=format&fit=crop', loc: 'Canggu', cls: '' },
];

const faqs = [
  { q: 'Berapa jauh hari sebaiknya booking prewedding?', a: 'Idealnya 2–3 bulan sebelum tanggal sesi. Untuk peak season (Mei–Oktober) sebaiknya 4 bulan, terutama kalau lokasi pilihan adalah Uluwatu / Nusa Penida yang sangat ramai.' },
  { q: 'Berapa lokasi bisa di-cover dalam 1 sesi?', a: '1–2 lokasi dalam 1 hari. Lebih dari itu biasanya rushed dan kurang maksimal. Untuk lokasi jauh (Nusa Penida, Karangasem), kami sarankan trip 2 hari.' },
  { q: 'Bagaimana kalau hujan saat sesi outdoor?', a: 'Kami pantau forecast 3 hari sebelum dan offer reschedule fleksibel. Atau pivot ke lokasi indoor (heritage hotel, villa). Hujan ringan kadang justru menghasilkan mood yang dramatic.' },
  { q: 'Apakah hair & make-up disertakan?', a: 'Tidak by default — tapi kami punya rekomendasi MUA langganan di Bali yang biasa kerjasama dengan kami. Bisa kami connect saat konsultasi.' },
  { q: 'Boleh bawa make-up artist/wardrobe sendiri?', a: 'Boleh banget. Banyak klien yang bawa MUA dari Jakarta atau outfit dari designer pilihan. Kami flexible.' },
  { q: 'Apakah hasilnya berwarna atau B&W?', a: 'Default berwarna dengan tone signature kami yang natural-sinematik. B&W disertakan untuk shot dengan mood kuat. Bisa di-discuss saat briefing.' },
];

const related = relatedTo('prewedding', 3);
---
<BaseLayout title={title} description={description} schema={schema}>
  <section class="subhero">
    <div class="subhero-img" style="background-image:url('https://images.unsplash.com/photo-1523438097201-512ae7d7c424?w=2000&q=85&auto=format&fit=crop')"></div>
    <div class="subhero-grain"></div>
    <div class="subhero-content">
      <div class="breadcrumb">
        <a href={url('/')} data-hover>Beranda</a>
        <span class="breadcrumb-sep"></span>
        <a href={url('/layanan/')} data-hover>Layanan</a>
        <span class="breadcrumb-sep"></span>
        <span class="breadcrumb-current">Prewedding</span>
      </div>
      <h1>Cerita cinta,<br /><em>sebelum hari H.</em></h1>
      <div class="subhero-meta">
        <div class="subhero-meta-text">"Sebuah excuse untuk pelan-pelan menikmati kebersamaan sebelum semuanya jadi sibuk hari pernikahan."</div>
        <div class="subhero-meta-tags">
          <span>Outdoor · Bali</span>
          <span>1–2 Lokasi</span>
          <span>Sinematik</span>
        </div>
      </div>
    </div>
  </section>

  <!-- INCLUDES -->
  <section class="section">
    <div class="section-inner" style="text-align:center">
      <div class="section-label reveal-up">— Yang Termasuk</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">Sesi yang <em>fokus</em><br />pada chemistry kalian.</h2>
    </div>
    <div class="incl-grid">
      {includes.map((it) => (
        <div class="incl-card reveal-up">
          <div class="incl-card-icon">{it.icon}</div>
          <div class="incl-card-name">{it.name}</div>
          <div class="incl-card-desc">{it.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- POPULAR LOCATIONS -->
  <section class="section section-alt">
    <div class="section-inner" style="text-align:center">
      <div class="section-label reveal-up">— Rekomendasi Lokasi</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">Setiap lokasi,<br /><em>cerita berbeda.</em></h2>
    </div>
    <ol class="feature-list reveal-up" style="margin-top:60px">
      {popularLocations.map((loc) => (
        <li>
          <div>
            <div class="feature-list-name">{loc.name}</div>
            <div class="feature-list-desc">{loc.desc}</div>
          </div>
          <div class="feature-list-meta">{loc.tag}</div>
        </li>
      ))}
    </ol>
  </section>

  <!-- WARDROBE TIPS -->
  <section class="section">
    <div class="section-inner-narrow" style="max-width:1100px;margin:0 auto">
      <div class="section-label reveal-up">— Wardrobe Tips</div>
      <h2 class="section-title reveal-up">Tampil <em>nyaman</em> & fotogenik.</h2>
      <p class="section-text reveal-up">
        Outfit yang tepat membuat sesi lebih menyenangkan dan hasilnya timeless. Tips di bawah berdasarkan ratusan sesi outdoor kami di Bali.
      </p>
    </div>
    <ol class="feature-list reveal-up" style="margin-top:60px">
      {wardrobeTips.map((t) => (
        <li>
          <div>
            <div class="feature-list-name">{t.name}</div>
            <div class="feature-list-desc">{t.desc}</div>
          </div>
          <div class="feature-list-meta">{t.meta}</div>
        </li>
      ))}
    </ol>
  </section>

  <!-- GALLERY -->
  <section class="section section-alt">
    <div class="section-inner" style="text-align:center">
      <div class="section-label reveal-up">— Karya Prewedding</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">Beberapa <em>cerita yang pernah kami foto.</em></h2>
    </div>
    <div class="gallery-grid" style="margin-top:60px">
      {gallery.map((g) => (
        <div class={`gallery-item ${g.cls}`} data-hover>
          <img src={g.src} alt={`Prewedding di ${g.loc}`} loading="lazy" />
          <div class="gallery-item-meta">{g.loc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="section-inner" style="text-align:center">
      <div class="section-label reveal-up">— Pertanyaan Umum</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">FAQ <em>seputar prewedding.</em></h2>
    </div>
    <ul class="faq-list" style="margin-top:60px">
      {faqs.map((item) => (
        <li class="faq-item reveal-up">
          <div class="faq-q">
            <span>{item.q}</span>
            <span class="faq-q-icon">+</span>
          </div>
          <div class="faq-a"><div class="faq-a-inner">{item.a}</div></div>
        </li>
      ))}
    </ul>
  </section>

  <CTA
    label="— Booking Prewedding"
    heading="Mari rencanakan<br /><em>sesi prewedding-mu.</em>"
    text="Konsultasi gratis lewat WhatsApp. Ceritakan lokasi pilihan, tema yang dibayangkan, dan timeline kalian — kita rancang sesi yang pas."
    showInfo={false}
  />

  <RelatedServices items={related.map((s) => ({ num: s.num, name: s.name, href: s.href, image: s.image }))} />
</BaseLayout>
