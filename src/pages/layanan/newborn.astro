---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import CTA from '../../components/home/CTA.astro';
import { url } from '../../utils/url';
import { relatedTo } from '../../data/services';

const title = 'Newborn Photography — Aman & Tenang';
const description =
  'Sesi newborn 5–14 hari setelah kelahiran di studio Julian Photography, Negara Jembrana. Safety protocol ketat, ruangan hangat, props bersih. Booking saat hamil 7 bulan.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Newborn Photography',
  description,
  provider: { '@id': 'https://juliansphotography.com/#business' },
  serviceType: 'Newborn Photography',
};

const includes = [
  { icon: 'I', name: 'Sesi Studio 3–4 Jam', desc: 'Durasi panjang karena bayi butuh banyak break: feeding, ganti popok, soothe. Tidak ada rush.' },
  { icon: 'II', name: 'Studio Hangat & Steril', desc: 'Ruangan dipanaskan ±27°C agar bayi nyaman tanpa pakaian. Semua props dicuci & disteril.' },
  { icon: 'III', name: 'Props & Wraps', desc: 'Koleksi keranjang, blanket, hat, headband, & wraps dengan berbagai warna & tekstur.' },
  { icon: 'IV', name: 'Posed + Lifestyle', desc: 'Foto posed klasik di props + lifestyle dengan orang tua untuk variasi cerita.' },
  { icon: 'V', name: 'Edited Hi-Res Photos', desc: '40–80 foto edited dengan tone soft & warm, siap cetak. Album fisik tersedia tambahan.' },
  { icon: 'VI', name: 'Online Gallery', desc: 'Akses gallery online untuk download high-res, mudah di-share ke keluarga jauh.' },
];

const safetyProtocol = [
  { name: 'Studio Steril', desc: 'Lantai, props, wraps, dan keranjang semua dicuci & disteril sebelum sesi. Tidak digunakan untuk hewan atau outdoor di hari yang sama.', meta: 'Higiene' },
  { name: 'Suhu Ruangan Hangat', desc: 'AC di-set ±27°C dengan space heater tambahan. Bayi nyaman tanpa pakaian — tidak akan kedinginan atau menggigil.', meta: 'Temperatur' },
  { name: 'No Flash, Cahaya Lembut', desc: 'Hanya pakai natural light atau soft continuous LED — tidak pernah pakai flash kuat di mata bayi yang baru terbentuk.', meta: 'Cahaya' },
  { name: 'Composite Posing', desc: 'Pose ekstrem (taco, frog) sebenarnya gabungan 2 foto dengan tangan parent menyangga di belakang. Tidak ada bayi yang ditinggal sendiri.', meta: 'Posing' },
  { name: 'Parents Always Present', desc: 'Salah satu orang tua selalu hadir & dekat bayi. Kami fotografer kerja sambil mama/papa stay siap menyangga.', meta: 'Pengawasan' },
  { name: 'Tidak Memaksakan Pose', desc: 'Kalau bayi rewel atau tidak mau di-pose tertentu, kami tidak paksa. Bayi yang tenang menghasilkan foto terbaik — bukan sebaliknya.', meta: 'Empati' },
];

const concepts = [
  { name: 'Posed (Studio Classic)', desc: 'Bayi di-pose dalam keranjang, blanket, atau wraps. Mata tertutup, postur curl alami. Set bersih, tone neutral.', tag: 'Posed' },
  { name: 'Lifestyle (Bersama Orang Tua)', desc: 'Bayi digendong/dipeluk mama-papa, sibling juga ikut. Setting kasual, mood hangat & natural.', tag: 'Lifestyle' },
  { name: 'Sibling Session', desc: 'Bayi bersama kakak yang lebih besar. Membutuhkan kesabaran ekstra & bribe favorit kakak (mainan, snack).', tag: 'Siblings' },
  { name: 'Detail Shots', desc: 'Close-up jari tangan, kaki, bibir, telinga — detail kecil yang akan kamu rindukan di kemudian hari.', tag: 'Details' },
];

const gallery = [
  { src: 'https://images.unsplash.com/photo-1555252333-9f8e92e65df9?w=1200&q=85&auto=format&fit=crop', loc: 'Posed Wrap', cls: 'gi-wide' },
  { src: 'https://images.unsplash.com/photo-1519689680058-324335c77eba?w=900&q=85&auto=format&fit=crop', loc: 'Basket Set', cls: 'gi-tall' },
  { src: 'https://images.unsplash.com/photo-1555252586-91d8d92a02e7?w=1000&q=85&auto=format&fit=crop', loc: 'With Mama', cls: '' },
  { src: 'https://images.unsplash.com/photo-1547089120-4ace65eafd49?w=1000&q=85&auto=format&fit=crop', loc: 'Detail', cls: '' },
  { src: 'https://images.unsplash.com/photo-1492366254240-43affaefc3e3?w=1000&q=85&auto=format&fit=crop', loc: 'Sibling', cls: '' },
  { src: 'https://images.unsplash.com/photo-1531983412531-1f49a365ffed?w=1200&q=85&auto=format&fit=crop', loc: 'Family', cls: 'gi-wide' },
];

const faqs = [
  { q: 'Kapan sebaiknya saya booking newborn?', a: 'Saat hamil 6–7 bulan. Slot newborn sangat terbatas karena timing 5–14 hari setelah lahir tidak bisa di-postpone. Begitu ketuban pecah, kabari kami untuk konfirmasi tanggal sesi.' },
  { q: 'Mengapa ideal 5–14 hari setelah lahir?', a: 'Di window ini bayi masih sleepy, fleksibel, dan bisa di-pose curl alami. Setelah 2 minggu bayi mulai aktif, bisa baby acne, dan lebih sulit di-arrange. Tidak masalah kalau lewat — kami adapt ke lifestyle session.' },
  { q: 'Bagaimana kalau bayi rewel atau menangis?', a: 'Itu normal. Kami tunggu, mama feeding/soothe dulu. Sesi 3–4 jam karena memang ada banyak break. Tidak ada deadline — bayi yang nyaman menghasilkan foto terbaik.' },
  { q: 'Apakah bisa request pose tertentu (taco, froggy)?', a: 'Untuk pose advanced kami evaluasi safety dulu. Pose ekstrem hanya dilakukan kalau bayi cooperative & ada parent menyangga (composite). Kami tidak akan memaksa.' },
  { q: 'Berapa lama hasil foto siap?', a: 'Sneak peek 5–10 foto dalam 1 minggu. Final delivery (full edited gallery) ±2–3 minggu setelah sesi.' },
  { q: 'Apakah kakak / hewan peliharaan boleh ikut?', a: 'Boleh banget — tapi sesi sibling/pets dilakukan di awal saat semua masih segar. Untuk pets, harap di-shower & kuku trim sebelum datang demi keamanan bayi.' },
];

const related = relatedTo('newborn', 3);
---
<BaseLayout title={title} description={description} schema={schema}>
  <section class="subhero">
    <div class="subhero-img" style="background-image:url('https://images.unsplash.com/photo-1555252333-9f8e92e65df9?w=2000&q=85&auto=format&fit=crop')"></div>
    <div class="subhero-grain"></div>
    <div class="subhero-content">
      <div class="breadcrumb">
        <a href={url('/')} data-hover>Beranda</a>
        <span class="breadcrumb-sep"></span>
        <a href={url('/layanan/')} data-hover>Layanan</a>
        <span class="breadcrumb-sep"></span>
        <span class="breadcrumb-current">Newborn</span>
      </div>
      <h1>Sesi pertama,<br /><em>untuk si kecil.</em></h1>
      <div class="subhero-meta">
        <div class="subhero-meta-text">"Hari-hari pertama berlalu cepat. Kami pelan-pelan, sabar, dan aman — agar setiap detail kecil terabadikan."</div>
        <div class="subhero-meta-tags">
          <span>Studio · Jembrana</span>
          <span>5–14 Hari</span>
          <span>3–4 Jam</span>
        </div>
      </div>
    </div>
  </section>

  <!-- INCLUDES -->
  <section class="section">
    <div class="section-inner" style="text-align:center">
      <div class="section-label reveal-up">— Yang Termasuk</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">Pengalaman <em>tanpa rush.</em></h2>
    </div>
    <div class="incl-grid">
      {includes.map((it) => (
        <div class="incl-card reveal-up">
          <div class="incl-card-icon">{it.icon}</div>
          <div class="incl-card-name">{it.name}</div>
          <div class="incl-card-desc">{it.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- SAFETY -->
  <section class="section section-alt">
    <div class="section-inner-narrow" style="max-width:1100px;margin:0 auto">
      <div class="section-label reveal-up">— Safety Protocol</div>
      <h2 class="section-title reveal-up">Keamanan bayi<br /><em>di atas segalanya.</em></h2>
      <p class="section-text reveal-up">
        Newborn bukan model — mereka rapuh dan butuh penanganan khusus. Berikut protokol yang selalu kami terapkan untuk setiap sesi tanpa kompromi.
      </p>
    </div>
    <ol class="feature-list reveal-up" style="margin-top:60px">
      {safetyProtocol.map((s) => (
        <li>
          <div>
            <div class="feature-list-name">{s.name}</div>
            <div class="feature-list-desc">{s.desc}</div>
          </div>
          <div class="feature-list-meta">{s.meta}</div>
        </li>
      ))}
    </ol>
  </section>

  <!-- CONCEPTS -->
  <section class="section">
    <div class="section-inner" style="text-align:center">
      <div class="section-label reveal-up">— Style Sesi</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">Pilih style<br /><em>yang sesuai cerita kalian.</em></h2>
    </div>
    <div class="incl-grid">
      {concepts.map((c) => (
        <div class="incl-card reveal-up">
          <div class="incl-card-icon">{c.tag.charAt(0)}</div>
          <div class="incl-card-name">{c.name}</div>
          <div class="incl-card-desc">{c.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section section-alt">
    <div class="section-inner" style="text-align:center">
      <div class="section-label reveal-up">— Karya Newborn</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">Setiap detail kecil,<br /><em>terdokumentasi.</em></h2>
    </div>
    <div class="gallery-grid" style="margin-top:60px">
      {gallery.map((g) => (
        <div class={`gallery-item ${g.cls}`} data-hover>
          <img src={g.src} alt={`Newborn ${g.loc}`} loading="lazy" />
          <div class="gallery-item-meta">{g.loc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="section-inner" style="text-align:center">
      <div class="section-label reveal-up">— Pertanyaan Umum</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">FAQ <em>seputar newborn.</em></h2>
    </div>
    <ul class="faq-list" style="margin-top:60px">
      {faqs.map((item) => (
        <li class="faq-item reveal-up">
          <div class="faq-q">
            <span>{item.q}</span>
            <span class="faq-q-icon">+</span>
          </div>
          <div class="faq-a"><div class="faq-a-inner">{item.a}</div></div>
        </li>
      ))}
    </ul>
  </section>

  <CTA
    label="— Booking Newborn"
    heading="Slot terbatas.<br />Booking <em>saat hamil 7 bulan.</em>"
    text="Karena timing 5–14 hari setelah lahir tidak bisa di-postpone, slot newborn cepat penuh. Konsultasi via WhatsApp untuk reservasi tanggal."
    showInfo={false}
  />

  <RelatedServices items={related.map((s) => ({ num: s.num, name: s.name, href: s.href, image: s.image }))} />
</BaseLayout>
