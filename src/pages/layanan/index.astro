---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/home/CTA.astro';
import { url } from '../../utils/url';
import { services } from '../../data/services';

const title = 'Layanan Fotografi — Julian Photography Bali';
const description =
  'Layanan foto Julian Photography: Wedding, Prewedding, Maternity, Newborn, Baby, Baby & Family, dan Family. Luar studio di seluruh Bali & dalam studio di Negara, Jembrana.';

const luarStudio = services.filter((s) => s.group === 'luar');
const dalamStudio = services.filter((s) => s.group === 'dalam');

// ItemList schema for SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Layanan Julian Photography',
  description,
  itemListElement: services.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Service',
      name: s.name,
      description: s.desc,
      url: `https://juliansphotography.com/id${s.href}`,
      provider: { '@id': 'https://juliansphotography.com/#business' },
    },
  })),
};
---
<BaseLayout title={title} description={description} schema={schema}>
  <!-- ====== SUB-HERO ====== -->
  <section class="subhero">
    <div class="subhero-img" style="background-image:url('https://images.unsplash.com/photo-1519741497674-611481863552?w=2000&q=85&auto=format&fit=crop')"></div>
    <div class="subhero-grain"></div>
    <div class="subhero-content">
      <div class="breadcrumb">
        <a href={url('/')} data-hover>Beranda</a>
        <span class="breadcrumb-sep"></span>
        <span class="breadcrumb-current">Layanan</span>
      </div>
      <h1>Tujuh layanan,<br /><em>untuk setiap babak hidupmu.</em></h1>
      <div class="subhero-meta">
        <div class="subhero-meta-text">"Dari pelukan pertama bayi yang baru lahir, sampai janji suci di pinggir tebing Uluwatu — setiap momenmu punya ruang di Julian Photography."</div>
        <div class="subhero-meta-tags">
          <span>Luar Studio · Bali</span>
          <span>Dalam Studio · Jembrana</span>
          <span>7 Layanan</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== INTRO ====== -->
  <section class="section">
    <div class="section-inner-narrow" style="max-width:980px;margin:0 auto;text-align:center">
      <div class="section-label reveal-up">— Kenapa Julian</div>
      <h2 class="section-title reveal-up" style="margin-left:auto;margin-right:auto">Satu tim, dua kategori,<br /><em>tujuh cerita.</em></h2>
      <p class="section-text reveal-up" style="margin-left:auto;margin-right:auto;text-align:left">
        Kami membagi layanan menjadi dua kategori: <strong>Luar Studio</strong> untuk liputan wedding & prewedding di seluruh Bali, dan <strong>Dalam Studio</strong> untuk sesi yang lebih intim — maternity, newborn, baby, hingga family — di studio kami di Negara, Jembrana. Setiap layanan punya pendekatan yang berbeda, tapi filosofinya sama: fokus pada momen, bukan pada pose.
      </p>
    </div>

    <!-- Stats strip -->
    <div class="info-strip reveal-up">
      <div class="info-strip-item">
        <div class="info-strip-label">Pengalaman</div>
        <div class="info-strip-value"><em>20+</em> tahun</div>
      </div>
      <div class="info-strip-item">
        <div class="info-strip-label">Layanan</div>
        <div class="info-strip-value"><em>7</em> kategori</div>
      </div>
      <div class="info-strip-item">
        <div class="info-strip-label">Area Liputan</div>
        <div class="info-strip-value">Seluruh <em>Bali</em></div>
      </div>
      <div class="info-strip-item">
        <div class="info-strip-label">Studio</div>
        <div class="info-strip-value">Negara, <em>Jembrana</em></div>
      </div>
    </div>
  </section>

  <!-- ====== LUAR STUDIO GROUP ====== -->
  <section class="section section-alt">
    <div class="service-group-label reveal-up" style="max-width:1400px;margin:0 auto 60px">
      <span class="service-group-num">I</span>
      <span class="service-group-name">Luar <em>Studio</em></span>
      <span class="service-group-meta">Outdoor · Bali</span>
    </div>

    <div class="section-inner-narrow" style="max-width:980px;margin:0 auto 60px">
      <p class="section-text reveal-up">
        Liputan di lokasi yang kamu pilih — dari tebing Uluwatu yang dramatis, sawah hijau Ubud, hingga pantai vulkanik Canggu. Kami familiar dengan timing & venue terbaik di setiap sudut Bali. Ideal untuk pasangan yang ingin latar belakang yang besar dan sinematik.
      </p>
    </div>

    <div class="hub-grid hub-grid-2">
      {luarStudio.map((s) => (
        <a class="hub-card reveal-up" href={url(s.href)} data-hover>
          <div class="hub-card-img">
            <img src={s.image} alt={s.name} loading="lazy" />
          </div>
          <div class="hub-card-body">
            <div class="hub-card-num">— {s.num}</div>
            <div class="hub-card-name">{s.name}</div>
            <p class="hub-card-desc">{s.desc}</p>
            <span class="page-link">
              Lihat Detail
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ====== DALAM STUDIO GROUP ====== -->
  <section class="section">
    <div class="service-group-label reveal-up" style="max-width:1400px;margin:0 auto 60px">
      <span class="service-group-num">II</span>
      <span class="service-group-name">Dalam <em>Studio</em></span>
      <span class="service-group-meta">Indoor · Jembrana</span>
    </div>

    <div class="section-inner-narrow" style="max-width:980px;margin:0 auto 60px">
      <p class="section-text reveal-up">
        Studio kami di Negara, Jembrana, didesain untuk sesi yang lebih personal — pencahayaan yang lembut, ruangan yang hangat, dan privacy yang terjaga. Ideal untuk momen-momen tenang: kehamilan, bayi yang baru lahir, milestone si kecil, hingga foto keluarga lintas generasi.
      </p>
    </div>

    <div class="hub-grid hub-grid-3">
      {dalamStudio.map((s) => (
        <a class="hub-card reveal-up" href={url(s.href)} data-hover>
          <div class="hub-card-img">
            <img src={s.image} alt={s.name} loading="lazy" />
          </div>
          <div class="hub-card-body">
            <div class="hub-card-num">— {s.num}</div>
            <div class="hub-card-name">{s.name}</div>
            <p class="hub-card-desc">{s.desc}</p>
            <span class="page-link">
              Lihat Detail
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ====== HOW IT WORKS ====== -->
  <section class="section section-alt">
    <div class="section-inner-narrow" style="max-width:1100px;margin:0 auto">
      <div class="section-label reveal-up">— Prosesnya</div>
      <h2 class="section-title reveal-up">Dari chat WhatsApp<br />hingga <em>album siap di tangan.</em></h2>
      <p class="section-text reveal-up">
        Semua layanan kami ikuti flow sederhana yang sama. Tidak ada deposit misterius, tidak ada biaya tersembunyi — yang kamu dapat adalah yang kami janjikan.
      </p>
    </div>
    <ol class="feature-list reveal-up" style="margin-top:60px">
      <li>
        <div>
          <div class="feature-list-name">Konsultasi</div>
          <div class="feature-list-desc">Chat via WhatsApp. Ceritakan layanan yang kamu cari, tanggal, lokasi, dan vibe yang dibayangkan. Kami respons dalam 24 jam dengan draft proposal.</div>
        </div>
        <div class="feature-list-meta">Hari 1</div>
      </li>
      <li>
        <div>
          <div class="feature-list-name">Booking & DP</div>
          <div class="feature-list-desc">Setelah proposal disetujui, booking diamankan dengan DP 30%. Invoice resmi dikirim via email. Tanggal kamu terkunci — tidak bisa dibooking orang lain.</div>
        </div>
        <div class="feature-list-meta">H-30+</div>
      </li>
      <li>
        <div>
          <div class="feature-list-name">Briefing</div>
          <div class="feature-list-desc">1–2 minggu sebelum sesi, kami ajak briefing via video call untuk finalisasi detail: timeline, must-have shot list, dress code, lokasi spesifik, dan logistik.</div>
        </div>
        <div class="feature-list-meta">H-7</div>
      </li>
      <li>
        <div>
          <div class="feature-list-name">Sesi Foto</div>
          <div class="feature-list-desc">Hari pemotretan. Kami datang tepat waktu, bawa peralatan lengkap (backup cameras, multiple lenses, lighting). Sisa 70% pembayaran dilunasi setelah sesi.</div>
        </div>
        <div class="feature-list-meta">Hari H</div>
      </li>
      <li>
        <div>
          <div class="feature-list-name">Sneak Peek</div>
          <div class="feature-list-desc">Dalam 3–7 hari, kami kirim 5–10 foto pilihan yang sudah edit. Untuk share ke keluarga, social media, atau sekedar kasih preview.</div>
        </div>
        <div class="feature-list-meta">H+7</div>
      </li>
      <li>
        <div>
          <div class="feature-list-name">Delivery Final</div>
          <div class="feature-list-desc">Full edited gallery (30–800+ foto tergantung layanan) dikirim via online gallery. Akses download tidak expired. Album fisik tambahan ±2–3 minggu.</div>
        </div>
        <div class="feature-list-meta">H+14 s/d H+60</div>
      </li>
    </ol>
  </section>

  <!-- ====== CTA ====== -->
  <CTA
    label="— Siap Memulai?"
    heading="Tujuh layanan,<br />satu <em>kontak yang sama.</em>"
    text="Tidak yakin layanan mana yang pas? Langsung chat — kami bantu pilihkan yang sesuai kebutuhan & budget kamu."
    showInfo={true}
  />
</BaseLayout>

<style>
  /* Hub grid — 2 cols for luar, 3 cols for dalam */
  .hub-grid {
    display: grid;
    gap: clamp(20px, 2.5vw, 32px);
    max-width: 1400px;
    margin: 0 auto;
  }
  .hub-grid-2 { grid-template-columns: repeat(2, 1fr); }
  .hub-grid-3 { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 1000px) {
    .hub-grid-3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 700px) {
    .hub-grid-2, .hub-grid-3 { grid-template-columns: 1fr; }
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--line);
    overflow: hidden;
    transition: transform .5s var(--ease), border-color .5s var(--ease);
    position: relative;
  }
  .hub-card:hover { transform: translateY(-6px); border-color: var(--accent); }

  .hub-card-img {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: #0d0d0d;
  }
  .hub-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: grayscale(.3);
    transform: scale(1.02);
    transition: filter 1s var(--ease), transform 1.4s var(--ease);
  }
  .hub-card:hover .hub-card-img img { filter: grayscale(0); transform: scale(1.08); }

  .hub-card-body { padding: clamp(24px, 3vw, 36px); display: flex; flex-direction: column; gap: 14px; }
  .hub-card-num { font-family: var(--serif); font-style: italic; font-size: 12px; color: var(--accent); letter-spacing: 2px; font-weight: 400; }
  .hub-card-name { font-family: var(--serif); font-size: clamp(24px, 2.5vw, 34px); font-weight: 300; letter-spacing: -.01em; line-height: 1.1; }
  .hub-card-desc { font-size: 14px; color: var(--fg-muted); line-height: 1.75; font-weight: 300; margin: 0; }
  .hub-card .page-link { margin-top: 8px; }
</style>
